; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GWJ 91"
run/main_scene="uid://ohxpkfy8oudh"
config/features=PackedStringArray("4.6")
config/icon="res://icon.png"

[autoload]

PhantomCameraManager="*uid://duq6jhf6unyis"
ToastX="*uid://3ka1c6fjlv6p"
TweenFX="*uid://d2n10rw2dnx8o"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"

[editor_plugins]

enabled=PackedStringArray("res://addons/Gedis/plugin.cfg", "res://addons/GedisQueue/plugin.cfg", "res://addons/TweenFX/plugin.cfg", "res://addons/health_bar_x/plugin.cfg", "res://addons/icon_widget/plugin.cfg", "res://addons/indie_game_components/plugin.cfg", "res://addons/maaacks_game_template/plugin.cfg", "res://addons/phantom_camera/plugin.cfg", "res://addons/toastx/plugin.cfg")

[global_group]

player=""
stage_camera=""
tick_time_label=""
debug_ui=""

